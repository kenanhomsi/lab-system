# Public URLs (used in the browser) — must match build args; change then rebuild: docker compose build --no-cache web
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Server-side: Next.js in the container calling your API (host machine or another container)
BACKEND_URL=http://host.docker.internal:4000
UPSTREAM_BACKEND_READY=false

# Optional: server-side bearer token for public website reads when upstream endpoints
# still require auth (e.g. GET /api/medical-tests). Remove once backend allows anonymous GET.
# BACKEND_PUBLIC_BEARER_TOKEN=

# Must be the public site URL in production (same as NEXT_PUBLIC_NEXTAUTH_URL).
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Cloud Messaging (Web) — from Firebase Console → Project settings
