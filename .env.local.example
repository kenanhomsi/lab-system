# =============================================================================
# BACKEND: mock by default (UI / full app without real API)
# =============================================================================
# EN: Leave UPSTREAM_BACKEND_READY unset or anything other than "true" → the app
#     uses mock responses everywhere (website, dashboard store, lab, special,
#     appointments, auth login, etc.). BACKEND_URL is ignored until you enable.
#
# AR: افتراضياً النظام كله mock — ما بيطلع طلب على السيرفر الحقيقي.
#     لما يصير الـ API جاهز، فعّل السطر التالي:
#
# UPSTREAM_BACKEND_READY=true

# Upstream API base URL (used only when UPSTREAM_BACKEND_READY=true)
BACKEND_URL=http://localhost:4000

# NextAuth
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000
