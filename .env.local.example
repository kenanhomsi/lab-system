# Upstream API base URL (no trailing slash required)
BACKEND_URL=http://localhost:4000

# While the real API is not ready, leave unset or false — BFF serves mock projects only.
# When your backend is live: UPSTREAM_BACKEND_READY=true
# UPSTREAM_BACKEND_READY=true

# NextAuth (configure when adding auth)
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000
